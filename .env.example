
# Server
PORT=8089
BASE_URL=http://localhost:8089
BASE_PATH=
PUBLIC_BASE=http://localhost:8089
TRUST_PROXY=1
ALLOWED_PUBLIC_HOSTS=localhost:8089,127.0.0.1:8089

# Session cookies
# COOKIE_SECURE: false for local HTTP, true for HTTPS, auto behind HTTPS proxy.
SESSION_SECRET=change_me_to_a_long_random_secret
COOKIE_SECURE=false

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_DOMAIN=http://localhost:8089/auth/discord/callback
DISCORD_CALLBACK_IP=http://localhost:8089/auth/discord/callback

# Admins and permissions
# Comma-separated Discord user IDs.
ADMINS=your_discord_user_id
CREATOR_ALLOW=your_discord_user_id

# Posts sync
POSTS_FULLSYNC_KEY=change_me_or_leave_empty

# Creator code bot integration
CREATOR_URL=/creator-tool
CREATOR_BOT_API_URL=http://127.0.0.1:8765/creator-code-add
CREATOR_BOT_API_SECRET=change_me_to_the_same_secret_as_the_bot
